import json
import os
from langchain_core.tools import tool
from langchain_core.messages import SystemMessage, HumanMessage
from langchain_groq import ChatGroq  # <--- Importiamo Groq invece di Gemini
from schemas import JudgeEvaluation

JUDGE_PROMPT = """Sei un revisore editoriale esperto (LLM-as-a-Judge). Il tuo compito è analizzare i risultati grezzi di una ricerca web (forniti in formato JSON) rispetto a un topic specifico.
Per ogni fonte nel JSON devi valutare:
1. **Accuratezza**: Analizza il contenuto e prendi in seria considerazione il 'score' di rilevanza quantitativo fornito da Tavily.
2. **Interesse/Qualità**: Valuta se il contenuto è utile e approfondito per i lettori del blog.

Seleziona solo le fonti migliori (is_selected: true) che superano i controlli di qualità."""

@tool
def information_judge_tool(tavily_json_str: str, topic: str) -> str:
    """Analizza il JSON grezzo restituito da Tavily per valutarne accuratezza, 
    punteggi di confidence (score) e qualità rispetto al topic.
    
    Argomenti:
        tavily_json_str: La stringa JSON grezza generata dal web_search_tool.
        topic: L'argomento del post corrente.
    """
    try:
        raw_data = json.loads(tavily_json_str.replace("'", '"')) #sostituiamo ' con " per essere sicuri di avere un dizionario
        results = raw_data.get("results", [])
        
        formatted_for_judge = []
        for idx, res in enumerate(results, 1): #scorriamo results, ma gli ids partono da 1
            formatted_for_judge.append(
                f"Fonte {idx}:\n"
                f"Titolo: {res.get('title')}\n"
                f"URL: {res.get('url')}\n"
                f"Tavily Score: {res.get('score')}\n"
                f"Contenuto Estratto: {res.get('content')}\n"
            )
        text_to_analyze = "\n".join(formatted_for_judge)
    except Exception as e:
        print(f"[JUDGE TOOL] Errore durante la formattazione dei risultati del web_search: {str(e)}")
        text_to_analyze = tavily_json_str #assegno comunque il contenuto del search per intero

    # Istanziamo modello da Groq
    judge_llm = ChatGroq(
        model="llama3-70b-8192", 
        temperature=0,
        groq_api_key=os.getenv("GROQ_API_KEY")
    )
    
    # Applichiamo lo schema Pydantic per forzare l'output strutturato da Groq
    structured_judge = judge_llm.with_structured_output(JudgeEvaluation)
    
    human_message_content = f"Topic: {topic}\n\nEcco i dati della ricerca da analizzare:\n{text_to_analyze}"
    
    try:
        evaluation: JudgeEvaluation = structured_judge.invoke([
            SystemMessage(content=JUDGE_PROMPT),
            HumanMessage(content=human_message_content)
        ])
        
        output_lines = [f"### VERDETTO DEL GIUDICE EDITORIALE (Valutato con Llama-3 su Groq):\n{evaluation.verdict_summary}\n"]
        for src in evaluation.evaluated_sources:
            status = "✅ APPROVATA" if src.is_selected else "❌ SCARTATA"
            output_lines.append(
                f"{status} | **{src.title}**\n"
                f"  - URL: {src.url}\n"
                f"  - Accuratezza: {src.accuracy_score}/10 | Interesse: {src.interestingness_score}/10\n"
                f"  - Analisi e Fact-checking: {src.justification}\n"
            )
        return "\n".join(output_lines)
        
    except Exception as e:
        return f"Errore critico durante la valutazione del giudice (Groq): {str(e)}"